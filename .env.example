# Mercado Brasil Daily — Configuração de Ambiente
#
# Copie este arquivo para .env e preencha com suas credenciais reais.
# NÃO commite o arquivo .env no git — use apenas para desenvolvimento local.
#
# Para produção, configure essas variáveis no seu systemd service ou CI/CD platform.

# ============================================================================
# MODELOS E APIs DE IA
# ============================================================================

# OpenRouter — Acesso a múltiplos modelos (Claude, Gemini, etc)
# https://openrouter.ai
# Obter chave em: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Modelo padrão para todos os agentes
# Opções: "google/gemini-2.5-flash" (recomendado), "anthropic/claude-opus-4.6"
OPENROUTER_MODEL=google/gemini-2.5-flash

# ============================================================================
# BUSCA DE NOTÍCIAS
# ============================================================================

# Tavily — Busca de notícias com RAG
# https://tavily.com
# Obter chave em: https://dashboard.tavily.com/api-keys
TAVILY_API_KEY=tvly-...

# Perigon — Agregador alternativo de notícias
# https://www.perigon.com
# Obter chave em: https://dashboard.perigon.com
PERIGON_API_KEY=perigon_...

# ============================================================================
# ENTREGA — TELEGRAM
# ============================================================================

# Telegram Bot Token
# Como obter:
#   1. Abra @BotFather no Telegram
#   2. Envie /newbot e siga as instruções
#   3. Copie o token fornecido
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Telegram Chat ID (seu ID pessoal ou de um grupo)
# Como obter:
#   1. Abra @userinfobot no Telegram
#   2. Envie /start
#   3. O bot retornará seu ID
# Ou:
#   1. Adicione o bot ao seu chat privado
#   2. Envie uma mensagem
#   3. Acesse https://api.telegram.org/bot<TOKEN>/getUpdates
#   4. Procure por "chat": {"id": <seu_id>}
TELEGRAM_CHAT_ID=123456789

# ============================================================================
# BANCO DE DADOS
# ============================================================================

# Caminho do banco de dados SQLite (local)
# Padrão: ./data/sqlite/digests.db
SQLITE_DB_PATH=./data/sqlite/digests.db

# ============================================================================
# DIRETÓRIOS
# ============================================================================

# Diretório de saída dos digests gerados
# Padrão: ./data/outputs
OUTPUT_DIR=./data/outputs

# ============================================================================
# CONFIGURAÇÕES OPCIONAIS
# ============================================================================

# Fuso horário para logs e timestampts
# Padrão: America/Sao_Paulo (BRT)
TZ=America/Sao_Paulo

# Nível de log (DEBUG, INFO, WARNING, ERROR)
# Padrão: INFO
LOG_LEVEL=INFO

# Modo debug — mostra outputs detalhados dos agentes
# true ou false
DEBUG_MODE=false

# ============================================================================
# NOTAS IMPORTANTES
# ============================================================================
#
# 1. SEGURANÇA
#    - NUNCA commite .env no git
#    - Use um .gitignore que inclua: *.env, .env.local, .env.*.local
#    - Para CI/CD (GitHub Actions, etc), use Secrets
#
# 2. DESENVOLVIMENTO LOCAL
#    - Copie este arquivo para .env
#    - Preencha com suas chaves reais
#    - Use python-dotenv que carrega automaticamente
#
# 3. PRODUÇÃO (systemd)
#    - Configure as variáveis no arquivo .service:
#    [Service]
#    Environment="OPENROUTER_API_KEY=sk-or-..."
#    Environment="TELEGRAM_BOT_TOKEN=..."
#    ...
#
# 4. VERIFICAR CONFIGURAÇÃO
#    - Execute: python -c "from config.settings import *; print('✓ Configuração OK')"
#    - Se houver erro, verifique as variáveis de ambiente
#
# ============================================================================
